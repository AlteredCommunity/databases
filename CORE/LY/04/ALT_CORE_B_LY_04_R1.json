                                "subject": "Flavor Text"
                            },
                            "text": "Avvistare una martingala è sempre di buon auspicio."
                        },
                        {
                            "@id": "/lore_entry_elements/01HNJH5T9CX5M7Z9RNHTSK9BZ8",
                            "@type": "LoreEntryElement",
                            "id": "01HNJH5T9CX5M7Z9RNHTSK9BZ8",
