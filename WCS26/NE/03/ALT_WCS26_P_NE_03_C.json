                        {
                            "@id": "/lore_entry_elements/01KH3ZWM8Z43AKVYZSVMX0FQGM",
                            "@type": "LoreEntryElement",
                            "id": "01KH3ZWM8Z43AKVYZSVMX0FQGM",
