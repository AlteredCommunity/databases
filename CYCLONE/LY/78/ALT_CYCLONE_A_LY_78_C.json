                        "reference": "FLAVOR_TEXT",
                        "subject": "Flavor Text"
                    },
                    "text": "Imagination, drawn from dreams."
                },
                {
                    "@id": "/lore_entry_elements/01JNRGBVFKEZAGPDKKK74ATNE9",
                    "@type": "LoreEntryElement",
                    "id": "01JNRGBVFKEZAGPDKKK74ATNE9",
