    "loreEntries": [
        {
            "@id": "/lore_entries/741K1KEG6P91NRKP1S9EDXPEZY",
            "@type": "LoreEntry",
            "id": "741K1KEG6P91NRKP1S9EDXPEZY",
            "loreEntryElements": [
                {
                    "@id": "/lore_entry_elements/01J21J283938ZJAESJ3RGQQN1S",
                    "@type": "LoreEntryElement",
                    "id": "01J21J283938ZJAESJ3RGQQN1S",
                    "loreEntryElementType": {
                        "@id": "/lore_entry_element_types/01GR6AENPX6HQP8G16KNV7BNA2",
                        "@type": "LoreEntryElementType",
                        "id": "01GR6AENPX6HQP8G16KNV7BNA2",
                        "reference": "FLAVOR_TEXT",
                        "subject": "Flavor Text"
                    },
                    "text": "Protecting the people of Asgartha is the greatest honor."
                },
                {
                    "@id": "/lore_entry_elements/01J21J2854F5TN2CY3K5BJEZN6",
                    "@type": "LoreEntryElement",
                    "id": "01J21J2854F5TN2CY3K5BJEZN6",
                    "loreEntryElementType": {
                        "@id": "/lore_entry_element_types/01GR6AE2ZSVVYP6SDJXN8Q5DVF",
                        "@type": "LoreEntryElementType",
                        "id": "01GR6AE2ZSVVYP6SDJXN8Q5DVF",
                        "reference": "STORY",
                        "subject": "Story"
                    },
                    "text": "I glance behind me as we walk and see my warrant officer diligently following me, her dual lance shining in the pinkish glow of the sunset. I'm just about to make a wisecrack when I remember that it's no longer Sunisa accompanying me but a completely new recruit. Sun is miles away, preparing to ascend the eastern flank of the Cais Adarra as per my orders. Nina's temperament is the exact opposite of my previous aide-de-camp's. Sunisa is cheeky and never at a loss for words, whereas Nina is much more discreet, even deferential, and it's a radical change for me. I've got nothing against her, but I have to admit that I miss Sun and her sharp tongue. But maybe it's just a matter of time until Nina feels comfortable enough to express her personality…\n\nAround us, the tree trunks are covered in mushrooms with red and blue caps, and spores drift through the air like snowflakes. It's actually pretty nice to be out of the dense thickets of conifers and in a much brighter and more spacious part of the woods. I hear a suspicious rustling a little way off, and I raise my fist. Nina stops immediately, her lance at the ready. Using our battle code, I instruct her to take up position on my flank and stay back as I slowly advance towards the source of the noise. If we run into Belisenki here, things could quickly turn ugly. I look at the tops of the trees, then the snow-covered embankments… It doesn't take long to identify the cause of the sound because it's making no effort to hide. It's a little snowman no higher than my knee, carrying a full set of camping gear on its back. A Chimaera? I decide to follow it…"
                },
                {
